---
const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;

interface NavItem {
  label: string;
  href: string;
  children?: { label: string; href: string }[];
}

const navItems: NavItem[] = [
  {
    label: 'Skills',
    href: `${base}/skills/`,
    children: [
      { label: 'Planning', href: `${base}/skills/?category=planning` },
      { label: 'Review', href: `${base}/skills/?category=review` },
      { label: 'GitOps', href: `${base}/skills/?category=gitops` },
      { label: 'Integrations', href: `${base}/skills/?category=integrations` },
    ],
  },
  {
    label: 'Workflows',
    href: `${base}/workflows/`,
  },
  {
    label: 'Guides',
    href: `${base}/guides/`,
  },
];

function isActive(href: string): boolean {
  const normalized = currentPath.replace(/\/$/, '');
  const target = href.replace(/\/$/, '').split('?')[0];
  return normalized === target || normalized.startsWith(target + '/');
}
---

<nav class="site-nav" aria-label="Main navigation">
  <div class="nav-inner">
    <a href={`${base}/`} class="nav-wordmark">
      SDLC<span class="nav-wordmark-sep">&thinsp;/&thinsp;</span>Marketplace
    </a>

    <button
      class="nav-toggle"
      aria-expanded="false"
      aria-controls="nav-menu"
      aria-label="Toggle navigation menu"
      type="button"
    >
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
        <line class="bar bar-1" x1="3" y1="5" x2="17" y2="5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
        <line class="bar bar-2" x1="3" y1="10" x2="17" y2="10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
        <line class="bar bar-3" x1="3" y1="15" x2="17" y2="15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
      </svg>
    </button>

    <ul id="nav-menu" class="nav-links" role="menubar">
      {navItems.map((item) => (
        <li class:list={['nav-item', { 'has-dropdown': !!item.children }]} role="none">
          <a
            href={item.href}
            class:list={['nav-link', { active: isActive(item.href) }]}
            role="menuitem"
            aria-haspopup={item.children ? 'true' : undefined}
          >
            {item.label}
            {item.children && (
              <svg class="dropdown-arrow" width="10" height="6" viewBox="0 0 10 6" fill="none" aria-hidden="true">
                <path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            )}
          </a>
          {item.children && (
            <ul class="dropdown" role="menu">
              {item.children.map((child) => (
                <li role="none">
                  <a href={child.href} class="dropdown-link" role="menuitem">
                    {child.label}
                  </a>
                </li>
              ))}
            </ul>
          )}
        </li>
      ))}
    </ul>
  </div>
</nav>

<script>
  const toggle = document.querySelector('.nav-toggle') as HTMLButtonElement | null;
  const menu = document.getElementById('nav-menu');

  if (toggle && menu) {
    toggle.addEventListener('click', () => {
      const expanded = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!expanded));
      menu.classList.toggle('open');
    });
  }
</script>

<style>
  .site-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    height: 3.5rem;
    background: color-mix(in srgb, var(--color-bg) 92%, transparent);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-border);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 72rem;
    margin: 0 auto;
    padding: 0 1.5rem;
    height: 100%;
  }

  .nav-wordmark {
    font-family: 'SF Mono', 'Fira Code', 'Fira Mono', 'Roboto Mono', 'Courier New', monospace;
    font-size: 0.875rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    color: var(--color-text);
    text-decoration: none;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .nav-wordmark:hover {
    color: var(--color-planning);
  }

  .nav-wordmark-sep {
    color: var(--color-text-muted);
    font-weight: 400;
  }

  .nav-toggle {
    display: none;
    background: none;
    border: none;
    color: var(--color-text-muted);
    cursor: pointer;
    padding: 0.25rem;
  }

  .nav-toggle:hover,
  .nav-toggle:focus-visible {
    color: var(--color-text);
  }

  .nav-toggle:focus-visible {
    outline: 2px solid var(--color-planning);
    outline-offset: 2px;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 0;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-item {
    position: relative;
  }

  .nav-link {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.5rem 0.875rem;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.12s ease;
  }

  .nav-link:hover {
    color: var(--color-text);
  }

  .nav-link:focus-visible {
    outline: 2px solid var(--color-planning);
    outline-offset: -2px;
    border-radius: 4px;
  }

  .nav-link.active {
    color: var(--color-text);
    box-shadow: inset 0 -2px 0 0 var(--color-planning);
  }

  .dropdown-arrow {
    transition: transform 0.15s ease;
  }

  /* Dropdown */
  .dropdown {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    min-width: 10rem;
    padding: 0.375rem 0;
    margin: 0.25rem 0 0;
    list-style: none;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    box-shadow: 0 8px 24px -4px rgba(0, 0, 0, 0.4);
  }

  .has-dropdown:hover .dropdown,
  .has-dropdown:focus-within .dropdown {
    display: block;
  }

  .has-dropdown:hover .dropdown-arrow,
  .has-dropdown:focus-within .dropdown-arrow {
    transform: rotate(180deg);
  }

  .dropdown-link {
    display: block;
    padding: 0.375rem 0.875rem;
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.1s ease, background 0.1s ease;
  }

  .dropdown-link:hover {
    color: var(--color-text);
    background: var(--color-surface-2);
  }

  .dropdown-link:focus-visible {
    outline: 2px solid var(--color-planning);
    outline-offset: -2px;
  }

  /* Mobile */
  @media (max-width: 640px) {
    .nav-toggle {
      display: block;
    }

    .nav-links {
      display: none;
      position: absolute;
      top: 3.5rem;
      left: 0;
      right: 0;
      flex-direction: column;
      align-items: stretch;
      background: var(--color-surface);
      border-bottom: 1px solid var(--color-border);
      padding: 0.5rem 0;
    }

    .nav-links.open {
      display: flex;
    }

    .nav-link {
      padding: 0.625rem 1.5rem;
    }

    .nav-link.active {
      box-shadow: inset 3px 0 0 0 var(--color-planning);
    }

    .dropdown {
      position: static;
      border: none;
      background: none;
      box-shadow: none;
      padding: 0;
      margin: 0;
      border-radius: 0;
    }

    .has-dropdown:hover .dropdown,
    .has-dropdown:focus-within .dropdown {
      display: block;
    }

    .dropdown-link {
      padding-left: 2.5rem;
    }
  }
</style>

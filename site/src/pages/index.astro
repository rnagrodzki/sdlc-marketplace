---
import BaseLayout from '../layouts/BaseLayout.astro';
import SkillCard from '../components/SkillCard.astro';
import WorkflowGraph from '../components/WorkflowGraph.astro';
import { skillsMeta, getSkillsByCategory } from '../data/skills-meta';

const base = import.meta.env.BASE_URL;

const categoryOrder = ['planning', 'review', 'gitops', 'integrations'] as const;
const categoryLabels = {
  planning: 'Planning & Execution',
  review: 'Code Review',
  gitops: 'Git Operations',
  integrations: 'Integrations',
};

const featureCards = [
  {
    title: 'Plan & Execute',
    color: 'var(--color-planning)',
    colorHex: '#3b82f6',
    href: `${base}/workflows/plan-execute/`,
    body: 'Use /plan-sdlc and /execute-plan-sdlc to decompose requirements into parallel task waves, then execute with adaptive intelligence.',
    icon: `<svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true"><rect x="2" y="3" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="1.5"/><rect x="11" y="3" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="1.5"/><rect x="2" y="12" width="7" height="5" rx="1.5" stroke="currentColor" stroke-width="1.5"/><rect x="11" y="12" width="7" height="5" rx="1.5" stroke="currentColor" stroke-width="1.5"/></svg>`,
  },
  {
    title: 'Multi-Dimension Review',
    color: 'var(--color-review)',
    colorHex: '#f59e0b',
    href: `${base}/workflows/review-cycle/`,
    body: '/review-sdlc dispatches parallel subagents across custom review dimensions, deduplicates findings, and posts structured PR comments.',
    icon: `<svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true"><circle cx="10" cy="10" r="7.5" stroke="currentColor" stroke-width="1.5"/><path d="M7 10l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  },
  {
    title: 'Ship with Confidence',
    color: 'var(--color-gitops)',
    colorHex: '#22c55e',
    href: `${base}/workflows/ship/`,
    body: 'From /commit-sdlc to /pr-sdlc to /version-sdlc — a complete git workflow with structured descriptions and semantic versioning.',
    icon: `<svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M10 2l2.5 5H17l-4 3 1.5 5L10 12l-4.5 3L7 10 3 7h4.5L10 2z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg>`,
  },
];

const installCmd = `/plugin marketplace add rnagrodzki/sdlc-marketplace\n/plugin install sdlc@sdlc-marketplace`;
---

<BaseLayout
  title="SDLC Utilities — Claude Code Plugin"
  description="10 skills for AI-driven code review, pull requests, planning, and releases — directly in your terminal."
>
  <!-- ============================================================
       HERO
  ============================================================ -->
  <section class="hero">
    <div class="hero-bg" aria-hidden="true"></div>
    <div class="hero-inner">
      <div class="hero-badge">
        <span class="hero-badge-dot"></span>
        Claude Code Plugin
      </div>

      <h1 class="hero-tagline">
        Automate Your SDLC<br />
        <span class="hero-tagline-accent">with Claude Code</span>
      </h1>

      <p class="hero-subtitle">
        10 skills for AI-driven code review, pull requests, planning,
        and releases — directly in your terminal.
      </p>

      <div class="hero-ctas">
        <a href={`${base}/getting-started/`} class="cta-primary">
          Get Started
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path d="M3 7h8m0 0L7 3m4 4L7 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a href={`${base}/skills/`} class="cta-secondary">Browse Skills</a>
      </div>

      <div class="hero-terminal">
        <div class="terminal-bar">
          <span class="terminal-dots" aria-hidden="true">
            <span></span><span></span><span></span>
          </span>
          <span class="terminal-title">Claude Code</span>
          <button
            class="copy-btn"
            data-copy={installCmd}
            aria-label="Copy install commands"
          >
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <rect x="4.5" y="4.5" width="8" height="8" rx="1.5" stroke="currentColor" stroke-width="1.25"/>
              <path d="M9.5 4.5V3a1 1 0 00-1-1H3a1 1 0 00-1 1v5.5a1 1 0 001 1h1.5" stroke="currentColor" stroke-width="1.25"/>
            </svg>
            Copy
          </button>
        </div>
        <div class="terminal-body">
          <div class="terminal-line">
            <span class="terminal-prompt">›</span>
            <code>/plugin marketplace add rnagrodzki/sdlc-marketplace</code>
          </div>
          <div class="terminal-line">
            <span class="terminal-prompt">›</span>
            <code>/plugin install sdlc@sdlc-marketplace</code>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       FEATURE HIGHLIGHTS
  ============================================================ -->
  <section class="features">
    <div class="section-inner">
      <div class="features-grid">
        {featureCards.map((card) => (
          <div
            class="feature-card"
            style={`--card-color: ${card.color}; --card-color-hex: ${card.colorHex};`}
          >
            <div class="feature-card-top" style={`color: ${card.color};`}>
              <span class="feature-icon" set:html={card.icon} />
            </div>
            <h3 class="feature-title">{card.title}</h3>
            <p class="feature-body">{card.body}</p>
            <a href={card.href} class="feature-link">
              Learn more
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                <path d="M2 6h8m0 0L6 2m4 4L6 10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================================
       SKILLS GRID
  ============================================================ -->
  <section class="skills-section">
    <div class="section-inner">
      <header class="section-header">
        <span class="section-overline">Plugin Catalog</span>
        <h2 class="section-title">All Skills</h2>
        <p class="section-subtitle">
          User-invocable skills for automating your software development lifecycle.
          Each skill is a structured pipeline that runs inside Claude Code.
        </p>
      </header>

      {categoryOrder.map(category => {
        const skills = getSkillsByCategory(category).filter(s => s.userInvocable);
        if (skills.length === 0) return null;
        return (
          <div class="category-block" data-category={category}>
            <h3 class="category-label">
              <span
                class="category-accent-bar"
                style={`background-color: var(--color-${category});`}
                aria-hidden="true"
              />
              {categoryLabels[category]}
            </h3>
            <div class="skills-grid">
              {skills.map(meta => (
                <SkillCard
                  slug={meta.slug}
                  command={meta.command}
                  tagline={meta.tagline}
                  category={meta.category}
                />
              ))}
            </div>
          </div>
        );
      })}

      <div class="skills-footer">
        <a href={`${base}/skills/`} class="cta-secondary">
          View all skills with pipeline details →
        </a>
      </div>
    </div>
  </section>

  <!-- ============================================================
       WORKFLOW PREVIEW
  ============================================================ -->
  <section class="workflow-section">
    <div class="section-inner">
      <header class="section-header">
        <span class="section-overline">System Map</span>
        <h2 class="section-title">How the Skills Connect</h2>
        <p class="section-subtitle">
          Skills compose into development lifecycle workflows — plan, review, ship.
          Hover any node to trace its connections across the system.
        </p>
      </header>

      <div class="workflow-graph-wrap">
        <WorkflowGraph />
      </div>

      <div class="workflow-footer">
        <a href={`${base}/workflows/`} class="cta-secondary">
          Explore full workflow map →
        </a>
      </div>
    </div>
  </section>

  <!-- ============================================================
       QUICK START
  ============================================================ -->
  <section class="quickstart-section">
    <div class="section-inner section-inner--narrow">
      <header class="section-header section-header--center">
        <span class="section-overline">Installation</span>
        <h2 class="section-title">Get Started in 3 Steps</h2>
      </header>

      <ol class="steps-list">
        <li class="step">
          <div class="step-number" aria-hidden="true">01</div>
          <div class="step-content">
            <h3 class="step-title">Install the plugin</h3>
            <p class="step-body">
              Add the marketplace and install the plugin directly from Claude Code.
              No npm, no config files — just two commands.
            </p>
            <div class="step-code-block">
              <div class="step-code-line">
                <span class="terminal-prompt">›</span>
                <code>/plugin marketplace add rnagrodzki/sdlc-marketplace</code>
              </div>
              <div class="step-code-line">
                <span class="terminal-prompt">›</span>
                <code>/plugin install sdlc@sdlc-marketplace</code>
              </div>
            </div>
          </div>
        </li>

        <li class="step">
          <div class="step-number" aria-hidden="true">02</div>
          <div class="step-content">
            <h3 class="step-title">Run your first skill</h3>
            <p class="step-body">
              Start with <code class="inline-code">/plan-sdlc</code> — describe what you want to build and let it
              decompose your requirements into a structured implementation plan with parallel task waves.
            </p>
            <div class="step-code-block">
              <div class="step-code-line">
                <span class="terminal-prompt">›</span>
                <code>/plan-sdlc Add user authentication with OAuth2 and session management</code>
              </div>
            </div>
          </div>
        </li>

        <li class="step">
          <div class="step-number" aria-hidden="true">03</div>
          <div class="step-content">
            <h3 class="step-title">Explore the full toolkit</h3>
            <p class="step-body">
              Browse all 10 skills or see the workflows to understand how they compose into a complete SDLC pipeline.
            </p>
            <div class="step-links">
              <a href={`${base}/skills/`} class="step-link">Browse skills →</a>
              <a href={`${base}/workflows/`} class="step-link">See workflows →</a>
              <a href={`${base}/getting-started/`} class="step-link">Full guide →</a>
            </div>
          </div>
        </li>
      </ol>
    </div>
  </section>
</BaseLayout>

<script is:inline>
  document.querySelectorAll('.copy-btn').forEach(function(btn) {
    var original = btn.innerHTML;
    btn.addEventListener('click', async function() {
      var text = btn.getAttribute('data-copy') || '';
      try {
        await navigator.clipboard.writeText(text);
        btn.textContent = 'Copied!';
        setTimeout(function() {
          btn.innerHTML = original;
        }, 2000);
      } catch (_) {
        // clipboard unavailable — silently ignore
      }
    });
  });
</script>

<style>
  /* ============================================================
     SHARED / LAYOUT
  ============================================================ */
  .section-inner {
    max-width: 72rem;
    margin: 0 auto;
    padding: 4rem 1.5rem;
  }

  .section-inner--narrow {
    max-width: 52rem;
  }

  .section-header {
    margin-bottom: 2.5rem;
  }

  .section-header--center {
    text-align: center;
  }

  .section-overline {
    display: inline-block;
    font-family: ui-monospace, 'SF Mono', 'Fira Code', monospace;
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-planning);
    margin-bottom: 0.75rem;
    padding: 3px 10px;
    border: 1px solid color-mix(in srgb, var(--color-planning) 30%, transparent);
    border-radius: 4px;
    background: color-mix(in srgb, var(--color-planning) 8%, transparent);
  }

  .section-title {
    font-family: ui-monospace, 'SF Mono', 'Fira Code', monospace;
    font-size: clamp(1.375rem, 3vw, 1.875rem);
    font-weight: 700;
    color: var(--color-text);
    margin: 0 0 0.75rem;
    letter-spacing: -0.01em;
  }

  .section-subtitle {
    font-size: 0.9375rem;
    line-height: 1.65;
    color: var(--color-text-muted);
    margin: 0;
    max-width: 52ch;
  }

  .section-header--center .section-subtitle {
    margin-left: auto;
    margin-right: auto;
  }

  /* ============================================================
     HERO
  ============================================================ */
  .hero {
    position: relative;
    padding: 5rem 1.5rem 4rem;
    overflow: hidden;
  }

  /* Dot-grid background */
  .hero-bg {
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(circle at 50% 0%, color-mix(in srgb, var(--color-planning) 10%, transparent) 0%, transparent 60%),
      radial-gradient(circle, #334155 0.7px, transparent 0.7px);
    background-size: auto, 24px 24px;
    opacity: 0.6;
    pointer-events: none;
  }

  .hero-inner {
    position: relative;
    max-width: 52rem;
    margin: 0 auto;
    text-align: center;
  }

  /* Badge */
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: ui-monospace, 'SF Mono', 'Fira Code', monospace;
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
    border-radius: 100px;
    padding: 4px 14px;
    background: var(--color-surface);
    margin-bottom: 2rem;
  }

  .hero-badge-dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-gitops);
    box-shadow: 0 0 6px var(--color-gitops);
    animation: pulse-dot 2s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  /* Tagline */
  .hero-tagline {
    font-family: ui-monospace, 'SF Mono', 'Fira Code', monospace;
    font-size: clamp(2rem, 6vw, 3.5rem);
    font-weight: 700;
    line-height: 1.1;
    color: var(--color-text);
    letter-spacing: -0.02em;
    margin: 0 0 1.25rem;
  }

  .hero-tagline-accent {
    background: linear-gradient(135deg, var(--color-planning) 0%, color-mix(in srgb, var(--color-planning) 60%, var(--color-review)) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* Subtitle */
  .hero-subtitle {
    font-size: clamp(1rem, 2.5vw, 1.125rem);
    line-height: 1.65;
    color: var(--color-text-muted);
    margin: 0 0 2.25rem;
    max-width: 44ch;
    margin-left: auto;
    margin-right: auto;
  }

  /* CTAs */
  .hero-ctas {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 2.5rem;
  }

  .cta-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 1.375rem;
    background: var(--color-planning);
    color: #fff;
    font-size: 0.9375rem;
    font-weight: 600;
    text-decoration: none;
    border-radius: 6px;
    transition: background 0.15s ease, box-shadow 0.15s ease, transform 0.12s ease;
  }

  .cta-primary:hover {
    background: color-mix(in srgb, var(--color-planning) 85%, #fff);
    box-shadow: 0 4px 20px -4px color-mix(in srgb, var(--color-planning) 50%, transparent);
    transform: translateY(-1px);
  }

  .cta-secondary {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.625rem 1.25rem;
    background: transparent;
    color: var(--color-text-muted);
    font-size: 0.9375rem;
    font-weight: 500;
    text-decoration: none;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    transition: color 0.15s ease, border-color 0.15s ease, background 0.15s ease;
  }

  .cta-secondary:hover {
    color: var(--color-text);
    border-color: color-mix(in srgb, var(--color-text) 40%, transparent);
    background: var(--color-surface);
  }

  /* Terminal block */
  .hero-terminal {
    max-width: 36rem;
    margin: 0 auto;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    background: var(--color-surface);
    overflow: hidden;
    text-align: left;
    box-shadow: 0 8px 40px -8px rgba(0, 0, 0, 0.5);
  }

  .terminal-bar {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.875rem;
    background: var(--color-surface-2);
    border-bottom: 1px solid var(--color-border);
  }

  .terminal-dots {
    display: flex;
    gap: 5px;
  }

  .terminal-dots span {
    display: block;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--color-border);
  }

  .terminal-dots span:nth-child(1) { background: #ef4444; }
  .terminal-dots span:nth-child(2) { background: #f59e0b; }
  .terminal-dots span:nth-child(3) { background: #22c55e; }

  .terminal-title {
    flex: 1;
    text-align: center;
    font-family: ui-monospace, 'SF Mono', 'Fira Code', monospace;
    font-size: 0.6875rem;
    color: var(--color-text-muted);
    letter-spacing: 0.05em;
  }

  .copy-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-family: ui-monospace, 'SF Mono', 'Fira Code', monospace;
    font-size: 0.6875rem;
    font-weight: 500;
    color: var(--color-text-muted);
    background: transparent;
    border: 1px solid var(--color-border);
    border-radius: 4px;
    padding: 2px 8px;
    cursor: pointer;
    transition: color 0.12s ease, border-color 0.12s ease, background 0.12s ease;
  }

  .copy-btn:hover {
    color: var(--color-text);
    border-color: color-mix(in srgb, var(--color-text) 30%, transparent);
    background: var(--color-bg);
  }

  .terminal-body {
    padding: 1rem 1.125rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .terminal-line {
    display: flex;
    align-items: baseline;
    gap: 0.625rem;
  }

  .terminal-prompt {
    color: var(--color-planning);
    font-family: ui-monospace, 'SF Mono', 'Fira Code', monospace;
    font-size: 0.8125rem;
    font-weight: 700;
    flex-shrink: 0;
    user-select: none;
  }

  .terminal-line code {
    font-family: ui-monospace, 'SF Mono', 'Fira Code', monospace;
    font-size: 0.8125rem;
    color: var(--color-text);
    word-break: break-all;
  }

  /* ============================================================
     FEATURES
  ============================================================ */
  .features {
    background: color-mix(in srgb, var(--color-surface) 30%, transparent);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.25rem;
  }

  .feature-card {
    position: relative;
    padding: 1.5rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-top: 3px solid var(--card-color);
    border-radius: 8px;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    transition: box-shadow 0.15s ease, transform 0.12s ease;
  }

  .feature-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 30px -6px color-mix(in srgb, var(--card-color) 25%, transparent);
  }

  .feature-card-top {
    margin-bottom: 0.25rem;
  }

  .feature-icon {
    display: inline-block;
    line-height: 0;
  }

  .feature-title {
    font-size: 1.0625rem;
    font-weight: 700;
    color: var(--color-text);
    margin: 0;
  }

  .feature-body {
    font-size: 0.875rem;
    line-height: 1.6;
    color: var(--color-text-muted);
    margin: 0;
    flex: 1;
  }

  .feature-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--card-color);
    text-decoration: none;
    margin-top: 0.5rem;
    transition: gap 0.12s ease, opacity 0.12s ease;
  }

  .feature-link:hover {
    gap: 0.5rem;
    opacity: 0.85;
  }

  /* ============================================================
     SKILLS GRID
  ============================================================ */
  .skills-section {
    border-bottom: 1px solid var(--color-border);
  }

  .category-block {
    margin-bottom: 2.5rem;
  }

  .category-block:last-of-type {
    margin-bottom: 0;
  }

  .category-label {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text);
    margin: 0 0 1rem;
  }

  .category-accent-bar {
    display: block;
    width: 3px;
    height: 1em;
    border-radius: 2px;
    flex-shrink: 0;
  }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 0.875rem;
  }

  .skills-footer {
    margin-top: 2rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
    text-align: center;
  }

  /* ============================================================
     WORKFLOW PREVIEW
  ============================================================ */
  .workflow-section {
    background: color-mix(in srgb, var(--color-surface) 20%, transparent);
    border-bottom: 1px solid var(--color-border);
  }

  .workflow-graph-wrap {
    border: 1px solid var(--color-border);
    border-radius: 8px;
    background: var(--color-bg);
    padding: 1.5rem;
    overflow: hidden;
    position: relative;
  }

  .workflow-footer {
    margin-top: 1.5rem;
    text-align: center;
  }

  /* ============================================================
     QUICK START
  ============================================================ */
  .quickstart-section {
    border-bottom: 1px solid var(--color-border);
  }

  .steps-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .step {
    display: grid;
    grid-template-columns: 3rem 1fr;
    gap: 1.25rem;
    padding: 2rem 0;
    border-bottom: 1px solid var(--color-border);
    position: relative;
  }

  .step:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  /* Vertical connector line */
  .step:not(:last-child)::after {
    content: '';
    position: absolute;
    left: 1.4375rem;
    top: calc(2rem + 2.25rem);
    bottom: 0;

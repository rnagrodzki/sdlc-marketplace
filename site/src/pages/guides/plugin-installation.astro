---
import { render, getEntry } from 'astro:content';
import GuideLayout from '../../layouts/GuideLayout.astro';

const entry = await getEntry('guides', 'plugin-installation');
if (!entry) throw new Error('plugin-installation.md not found in guides collection');
const { Content } = await render(entry);
---

<GuideLayout title="Plugin Installation" description="How plugins are installed, discovered, and resolved at runtime in Claude Code.">
  <Content />
</GuideLayout>

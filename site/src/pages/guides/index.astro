---
import BaseLayout from '../../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL;

const guides = [
  {
    title: 'Plugin Installation',
    description: 'Install and configure the sdlc-utilities plugin in your Claude Code environment.',
    href: `${base}/guides/plugin-installation/`,
  },
  {
    title: 'Adding Skills',
    description: 'Create project-specific skills and add them to your plugin.',
    href: `${base}/guides/adding-skills/`,
  },
  {
    title: 'Adding Hooks',
    description: 'Configure session hooks to automate actions triggered by Claude Code events.',
    href: `${base}/guides/adding-hooks/`,
  },
];
---

<BaseLayout
  title="Guides — SDLC Utilities"
  description="How-to guides for installing, configuring, and extending the sdlc-utilities plugin."
>
  <div class="guides-page">
    <header class="page-header">
      <h1 class="page-title">Guides</h1>
      <p class="page-description">
        Step-by-step guides for installing and extending the sdlc-utilities plugin.
      </p>
    </header>

    <div class="guide-grid">
      {guides.map(guide => (
        <a href={guide.href} class="guide-card">
          <h2 class="guide-card-title">{guide.title}</h2>
          <p class="guide-card-description">{guide.description}</p>
          <span class="guide-card-arrow" aria-hidden="true">→</span>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .guides-page {
    max-width: 72rem;
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
  }

  .page-header {
    margin-bottom: 3rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .page-title {
    margin: 0 0 0.75rem;
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-text);
    line-height: 1.2;
  }

  .page-description {
    margin: 0;
    font-size: 1rem;
    color: var(--color-text-muted);
    max-width: 60ch;
    line-height: 1.6;
  }

  .guide-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(22rem, 1fr));
    gap: 1rem;
  }

  .guide-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.25rem 1.5rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    text-decoration: none;
    transition: border-color 0.15s ease, background 0.15s ease;
    position: relative;
  }

  .guide-card:hover {
    border-color: var(--color-planning);
    background: color-mix(in srgb, var(--color-surface) 90%, var(--color-planning));
  }

  .guide-card-title {
    margin: 0;
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text);
    line-height: 1.3;
  }

  .guide-card-description {
    margin: 0;
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.5;
    flex: 1;
  }

  .guide-card-arrow {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    transition: color 0.15s ease, transform 0.15s ease;
    display: inline-block;
    align-self: flex-end;
  }

  .guide-card:hover .guide-card-arrow {
    color: var(--color-planning);
    transform: translateX(3px);
  }

  @media (max-width: 640px) {
    .guide-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

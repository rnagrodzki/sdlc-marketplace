---
import { render, getEntry } from 'astro:content';
import GuideLayout from '../../layouts/GuideLayout.astro';

const entry = await getEntry('guides', 'adding-skills');
if (!entry) throw new Error('adding-skills.md not found in guides collection');
const { Content } = await render(entry);
---

<GuideLayout title="Adding Skills" description="How to create custom skills for your project using the SDLC Marketplace plugin system.">
  <Content />
</GuideLayout>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SkillCard from '../../components/SkillCard.astro';
import { getSkillsByCategory } from '../../data/skills-meta';

const categoryOrder = ['planning', 'review', 'gitops', 'integrations'] as const;
const categoryLabels = {
  planning: 'Planning & Execution',
  review: 'Code Review',
  gitops: 'Git Operations',
  integrations: 'Integrations',
};
---

<BaseLayout
  title="Skills — SDLC Utilities"
  description="All skills available in the sdlc-utilities plugin for Claude Code."
>
  <div class="skills-page">
    <header class="page-header">
      <h1 class="page-title">Skills</h1>
      <p class="page-description">
        User-invocable skills for automating your software development lifecycle. Each skill is a
        structured pipeline that runs inside Claude Code.
      </p>
    </header>

    {categoryOrder.map(category => {
      const skills = getSkillsByCategory(category).filter(s => s.userInvocable);
      if (skills.length === 0) return null;
      return (
        <section class="category-section" data-category={category}>
          <h2 class="category-heading">
            <span class="category-label">{categoryLabels[category]}</span>
            <span class="category-underline" style={`background-color: var(--color-${category});`} />
          </h2>
          <div class="skill-grid">
            {skills.map(meta => (
              <SkillCard
                slug={meta.slug}
                command={meta.command}
                tagline={meta.tagline}
                category={meta.category}
              />
            ))}
          </div>
        </section>
      );
    })}

  </div>
</BaseLayout>

<style>
  .skills-page {
    max-width: 72rem;
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
  }

  .page-header {
    margin-bottom: 3rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .page-title {
    margin: 0 0 0.75rem;
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-text);
    line-height: 1.2;
  }

  .page-description {
    margin: 0;
    font-size: 1rem;
    color: var(--color-text-muted);
    max-width: 60ch;
    line-height: 1.6;
  }

  .category-section {
    margin-bottom: 3rem;
  }

  .category-heading {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    margin: 0 0 1.25rem;
  }

  .category-label {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-text);
    line-height: 1.3;
  }

  .category-underline {
    display: block;
    width: 2.5rem;
    height: 2px;
    border-radius: 1px;
  }

  .skill-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(22rem, 1fr));
    gap: 1rem;
  }

  @media (max-width: 640px) {
    .skill-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import WorkflowGraph from '../../components/WorkflowGraph.astro';

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Spec-Driven Development" description="How OpenSpec specifications combine with SDLC skills for spec-driven implementation.">
  <section class="wd-hero">
    <div class="wd-hero-inner">
      <a href={`${base}/workflows/`} class="wd-back">&larr; All Workflows</a>
      <span class="wd-overline" style="--lane-color: var(--color-integrations);">Integration</span>
      <h1 class="wd-title">Spec-Driven Development</h1>
      <p class="wd-subtitle">
        Combine OpenSpec specifications with SDLC execution — from proposals through delta specs to verified, reviewed implementations.
      </p>
    </div>
  </section>

  <section class="wd-graph-section">
    <div class="wd-graph-container">
      <WorkflowGraph highlightSlugs={['plan-sdlc', 'execute-plan-sdlc', 'review-sdlc']} />
    </div>
  </section>

  <section class="wd-content">
    <div class="wd-content-inner">
      <div class="wd-steps">
        <div class="wd-step" style="--step-color: var(--color-integrations);">
          <div class="wd-step-marker">1</div>
          <div class="wd-step-body">
            <h2 class="wd-step-title">
              Propose & Spec with OpenSpec
            </h2>
            <p>
              Start with <code>/opsx:propose</code> to create a change proposal capturing intent, scope, and capabilities. Then run <code>/opsx:continue</code> to develop delta specs with ADDED/MODIFIED/REMOVED sections, a technical design document, and a high-level task checklist.
            </p>
            <p>
              These artifacts live in <code>openspec/changes/&lt;name&gt;/</code> and become the authoritative requirements for SDLC skills. OpenSpec owns the spec workflow — SDLC skills consume the output read-only.
            </p>
          </div>
        </div>

        <div class="wd-step" style="--step-color: var(--color-planning);">
          <div class="wd-step-marker">2</div>
          <div class="wd-step-body">
            <h2 class="wd-step-title">
              Plan with
              <a href={`${base}/skills/plan-sdlc/`} class="wd-skill-link">/plan-sdlc</a>
            </h2>
            <p>
              Run <code>/plan-sdlc --spec</code> to load the OpenSpec artifacts as requirements. The skill reads the proposal for scope, delta specs for detailed requirements, and the design document for architecture constraints. Every ADDED and MODIFIED entry maps to at least one implementation task.
            </p>
            <p>
              For functional changes, plan-sdlc also detects OpenSpec automatically — even without <code>--spec</code>. If you describe a new feature, it proposes switching to the spec-first workflow before planning begins.
            </p>
          </div>
        </div>

        <div class="wd-step" style="--step-color: var(--color-planning);">
          <div class="wd-step-marker">3</div>
          <div class="wd-step-body">
            <h2 class="wd-step-title">
              Execute & Verify with
              <a href={`${base}/skills/execute-plan-sdlc/`} class="wd-skill-link">/execute-plan-sdlc</a>
            </h2>
            <p>
              Wave-based parallel execution dispatches agents per task. When the plan's Source field points to an OpenSpec change, the spec compliance reviewer checks implementations against the delta spec requirements — not just task acceptance criteria.
            </p>
            <p>
              After execution, run <code>/review-sdlc</code> with the spec-compliance-review dimension installed to get a multi-dimensional review that includes spec adherence.
            </p>
          </div>
        </div>

        <div class="wd-step" style="--step-color: var(--color-gitops);">
          <div class="wd-step-marker">4</div>
          <div class="wd-step-body">
            <h2 class="wd-step-title">
              Ship & Archive
            </h2>
            <p>
              Package changes with <code>/commit-sdlc</code> (which uses the OpenSpec change name as a scope hint) and <code>/pr-sdlc</code> (which auto-detects OpenSpec and pre-fills Business Context from the proposal). The PR description traces back to the spec.
            </p>
            <p>
              Close the loop with <code>/opsx:verify</code> to validate implementation completeness and <code>/opsx:archive</code> to merge delta specs into the project's main specifications.
            </p>
          </div>
        </div>
      </div>

      <div class="wd-after">
        <h2 class="wd-after-title">What happens next?</h2>
        <div class="wd-after-paths">
          <a href={`${base}/workflows/plan-execute/`} class="wd-after-path" style="--path-color: var(--color-planning);">
            <span class="wd-path-label">Deep dive into planning</span>
            <span class="wd-path-desc">See how plan-sdlc decomposes requirements and execute-plan-sdlc runs waves</span>
          </a>
          <a href={`${base}/workflows/review-cycle/`} class="wd-after-path" style="--path-color: var(--color-review);">
            <span class="wd-path-label">Set up spec compliance review</span>
            <span class="wd-path-desc">Install the spec-compliance-review dimension for ongoing spec adherence checks</span>
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .wd-hero {
    padding: 3rem 1.5rem 1.5rem;
  }

  .wd-hero-inner {
    max-width: 40rem;
    margin: 0 auto;
  }

  .wd-back {
    display: inline-block;
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    text-decoration: none;
    margin-bottom: 1rem;
    transition: color 0.12s ease;
  }

  .wd-back:hover {
    color: var(--color-text);
  }

  .wd-overline {
    display: inline-block;
    font-family: ui-monospace, 'SF Mono', 'Fira Code', monospace;
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--lane-color);
    margin-bottom: 0.75rem;
    padding: 3px 10px;
    border: 1px solid color-mix(in srgb, var(--lane-color) 30%, transparent);
    border-radius: 4px;
    background: color-mix(in srgb, var(--lane-color) 8%, transparent);
  }

  .wd-title {
    font-family: ui-monospace, 'SF Mono', 'Fira Code', monospace;
    font-size: clamp(1.5rem, 4vw, 2rem);
    font-weight: 700;
    color: var(--color-text);
    margin: 0 0 0.75rem;
    letter-spacing: -0.01em;
  }

  .wd-subtitle {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--color-text-muted);
    margin: 0;
  }

  .wd-graph-section {
    padding: 1rem 1.5rem 2rem;
  }

  .wd-graph-container {
    max-width: 72rem;
    margin: 0 auto;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    background: var(--color-bg);
    padding: 1.5rem;
    overflow: hidden;
  }

  .wd-content {
    padding: 0 1.5rem 3rem;
  }

  .wd-content-inner {
    max-width: 40rem;
    margin: 0 auto;
  }

  /* --- Steps --- */
  .wd-steps {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    margin-bottom: 3rem;
  }

  .wd-step {
    display: flex;
    gap: 1.25rem;
    position: relative;
  }

  .wd-step-marker {
    flex-shrink: 0;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: color-mix(in srgb, var(--step-color) 15%, transparent);
    border: 1.5px solid color-mix(in srgb, var(--step-color) 40%, transparent);
    color: var(--step-color);
    font-family: ui-monospace, 'SF Mono', 'Fira Code', monospace;
    font-size: 0.75rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 0.125rem;
  }

  .wd-step-body {
    flex: 1;
    min-width: 0;
  }

  .wd-step-title {
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--color-text);
    margin: 0 0 0.625rem;
    line-height: 1.4;
  }

  .wd-skill-link {
    font-family: ui-monospace, 'SF Mono', 'Fira Code', monospace;
    font-size: 0.9375rem;
    color: var(--step-color);
    text-decoration: none;
    border-bottom: 1px solid color-mix(in srgb, var(--step-color) 30%, transparent);
    transition: border-color 0.12s ease;
  }

  .wd-skill-link:hover {
    border-color: var(--step-color);
  }

  .wd-step-body p {
    font-size: 0.875rem;
    line-height: 1.65;
    color: var(--color-text-muted);
    margin: 0 0 0.75rem;
  }

  .wd-step-body p:last-child {
    margin-bottom: 0;
  }

  /* --- After section --- */
  .wd-after-title {
    font-family: ui-monospace, 'SF Mono', 'Fira Code', monospace;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin: 0 0 1rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }

  .wd-after-paths {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .wd-after-path {
    display: block;
    padding: 1rem 1rem 1rem 1.125rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-left: 3px solid var(--path-color);
    border-radius: 6px;
    text-decoration: none;
    transition: transform 0.12s ease, box-shadow 0.12s ease;
  }

  .wd-after-path:hover {
    transform: translateY(-1px);
    box-shadow: 0 2px 12px -2px color-mix(in srgb, var(--path-color) 15%, transparent);
  }

  .wd-path-label {
    display: block;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 0.375rem;
  }

  .wd-path-desc {
    display: block;
    font-size: 0.75rem;
    line-height: 1.5;
    color: var(--color-text-muted);
  }

  @media (max-width: 640px) {
    .wd-hero {
      padding: 2rem 1rem 1rem;
    }

    .wd-graph-section,
    .wd-content {
      padding-left: 1rem;
      padding-right: 1rem;
    }

    .wd-graph-container {
      padding: 1rem;
    }

    .wd-after-paths {
      grid-template-columns: 1fr;
    }
  }
</style>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import WorkflowGraph from '../../components/WorkflowGraph.astro';

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Ship Workflow" description="Automated shipping pipeline: execute, commit, review, fix, version, and PR — orchestrated by ship-sdlc or invoked individually.">
  <section class="wd-hero">
    <div class="wd-hero-inner">
      <a href={`${base}/workflows/`} class="wd-back">&larr; All Workflows</a>
      <span class="wd-overline" style="--lane-color: var(--color-gitops);">Ship Lane</span>
      <h1 class="wd-title">Ship with Confidence</h1>
      <p class="wd-subtitle">
        One command runs the full pipeline — execute, commit, review, fix, version, PR.
        Or invoke each skill individually when you need fine-grained control.
      </p>
    </div>
  </section>

  <section class="wd-graph-section">
    <div class="wd-graph-container">
      <WorkflowGraph highlightSlugs={['commit-sdlc', 'pr-sdlc', 'version-sdlc', 'ship-sdlc']} />
    </div>
  </section>

  <section class="wd-content">
    <div class="wd-content-inner">

      <!-- Automated Pipeline Section -->
      <div class="sp-section">
        <h2 class="sp-section-title">
          Automated Pipeline
          <a href={`${base}/skills/ship-sdlc/`} class="wd-skill-link" style="--step-color: var(--color-gitops);">/ship-sdlc</a>
        </h2>
        <p class="sp-section-desc">
          Orchestrates the full shipping flow in one invocation. Each step delegates to a dedicated skill,
          forwarding flags and respecting <code>--auto</code> mode where possible.
        </p>

        <div class="sp-pipeline">
          <!-- Step 1: Execute Plan -->
          <div class="sp-step">
            <div class="sp-step-number">1</div>
            <a href={`${base}/skills/execute-plan-sdlc/`} class="sp-step-box">
              <span class="sp-step-label">Execute Plan</span>
              <span class="sp-step-skill">execute-plan-sdlc</span>
            </a>
          </div>

          <div class="sp-connector"></div>

          <!-- Step 2: Commit Changes -->
          <div class="sp-step">
            <div class="sp-step-number">2</div>
            <a href={`${base}/skills/commit-sdlc/`} class="sp-step-box">
              <span class="sp-step-label">Commit Changes</span>
              <span class="sp-step-skill">commit-sdlc</span>
            </a>
          </div>

          <div class="sp-connector"></div>

          <!-- Step 3: Code Review -->
          <div class="sp-step">
            <div class="sp-step-number">3</div>
            <a href={`${base}/skills/review-sdlc/`} class="sp-step-box">
              <span class="sp-step-label">Code Review</span>
              <span class="sp-step-skill">review-sdlc</span>
            </a>
          </div>

          <div class="sp-connector"></div>

          <!-- Conditional Branch: Review Verdict -->
          <div class="sp-branch">
            <div class="sp-branch-diamond">
              <span class="sp-branch-text">Critical / High findings?</span>
            </div>
            <div class="sp-branch-paths">
              <div class="sp-branch-yes">
                <span class="sp-branch-label sp-branch-label--yes">yes</span>
                <div class="sp-connector sp-connector--branch"></div>
                <div class="sp-step sp-step--branch">
                  <div class="sp-step-number">4</div>
                  <a href={`${base}/skills/received-review-sdlc/`} class="sp-step-box sp-step-box--conditional">
                    <span class="sp-step-label">Fix Issues</span>
                    <span class="sp-step-skill">received-review-sdlc</span>
                    <span class="sp-badge sp-badge--pause">pauses</span>
                  </a>
                </div>
              </div>
              <div class="sp-branch-no">
                <span class="sp-branch-label sp-branch-label--no">no</span>
              </div>
            </div>
          </div>

          <div class="sp-connector sp-connector--merge"></div>

          <!-- Step 5: Commit Fixes -->
          <div class="sp-step">
            <div class="sp-step-number">5</div>
            <a href={`${base}/skills/commit-sdlc/`} class="sp-step-box sp-step-box--conditional">
              <span class="sp-step-label">Commit Fixes</span>
              <span class="sp-step-skill">commit-sdlc</span>
              <span class="sp-badge sp-badge--conditional">if fixes made</span>
            </a>
          </div>

          <div class="sp-connector"></div>

          <!-- Step 6: Version & Tag -->
          <div class="sp-step">
            <div class="sp-step-number">6</div>
            <a href={`${base}/skills/version-sdlc/`} class="sp-step-box">
              <span class="sp-step-label">Version &amp; Tag</span>
              <span class="sp-step-skill">version-sdlc</span>
              <span class="sp-badge sp-badge--pause">pauses</span>
            </a>
          </div>

          <div class="sp-connector"></div>

          <!-- Step 7: Open PR -->
          <div class="sp-step">
            <div class="sp-step-number">7</div>
            <a href={`${base}/skills/pr-sdlc/`} class="sp-step-box">
              <span class="sp-step-label">Open PR</span>
              <span class="sp-step-skill">pr-sdlc</span>
            </a>
          </div>
        </div>
      </div>

      <!-- Auto Mode Audit Table -->
      <div class="sp-section">
        <h2 class="sp-section-title">Auto Mode Behavior</h2>
        <p class="sp-section-desc">
          With <code>--auto</code>, ship-sdlc runs the pipeline with minimal interaction.
          Two steps always pause for human input.
        </p>
        <div class="sp-table-wrap">
          <table class="sp-table">
            <thead>
              <tr>
                <th>Step</th>
                <th>Skill</th>
                <th>Auto Behavior</th>
                <th>Pauses?</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>Execute</td>
                <td><a href={`${base}/skills/execute-plan-sdlc/`}>execute-plan-sdlc</a></td>
                <td><code>--preset</code> forwarded</td>
                <td><span class="sp-pause-no">No</span></td>
              </tr>
              <tr>
                <td>Commit</td>
                <td><a href={`${base}/skills/commit-sdlc/`}>commit-sdlc</a></td>
                <td><code>--auto</code> forwarded</td>
                <td><span class="sp-pause-no">No</span></td>
              </tr>
              <tr>
                <td>Review</td>
                <td><a href={`${base}/skills/review-sdlc/`}>review-sdlc</a></td>
                <td>Read-only</td>
                <td><span class="sp-pause-no">No</span></td>
              </tr>
              <tr>
                <td>Fix Issues</td>
                <td><a href={`${base}/skills/received-review-sdlc/`}>received-review-sdlc</a></td>
                <td>Always interactive</td>
                <td><span class="sp-pause-yes">Yes</span></td>
              </tr>
              <tr>
                <td>Version</td>
                <td><a href={`${base}/skills/version-sdlc/`}>version-sdlc</a></td>
                <td>Bump type pre-set</td>
                <td><span class="sp-pause-yes">Yes</span></td>
              </tr>
              <tr>
                <td>PR</td>
                <td><a href={`${base}/skills/pr-sdlc/`}>pr-sdlc</a></td>
                <td><code>--auto</code> forwarded</td>
                <td><span class="sp-pause-no">No</span></td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Individual Skills -->
      <div class="sp-section">
        <h2 class="sp-section-title">Individual Skills</h2>
        <p class="sp-section-desc">
          Each pipeline step is a standalone skill. Use them independently when you don't need the full pipeline.
        </p>

        <div class="wd-steps">
          <div class="wd-step" style="--step-color: var(--color-gitops);">
            <div class="wd-step-marker">1</div>
            <div class="wd-step-body">
              <h3 class="wd-step-title">
                Commit with
                <a href={`${base}/skills/commit-sdlc/`} class="wd-skill-link">/commit-sdlc</a>
              </h3>
              <p>
                Stashes unstaged changes, analyzes the staged diff alongside recent commit history
                to detect the project's commit style, then generates a matching commit message.
                You review and approve before the commit executes. The stash is restored after.
              </p>
            </div>
          </div>

          <div class="wd-step" style="--step-color: var(--color-gitops);">
            <div class="wd-step-marker">2</div>
            <div class="wd-step-body">
              <h3 class="wd-step-title">
                Open PR with
                <a href={`${base}/skills/pr-sdlc/`} class="wd-skill-link">/pr-sdlc</a>
              </h3>
              <p>
                Analyzes all branch commits and the full diff to generate a structured PR description.
                Uses an 8-section default template or your custom template from
                <a href={`${base}/skills/pr-customize-sdlc/`} class="wd-skill-link">/pr-customize-sdlc</a>.
                Handles multi-account GitHub setups automatically.
              </p>
            </div>
          </div>

          <div class="wd-step" style="--step-color: var(--color-gitops);">
            <div class="wd-step-marker">3</div>
            <div class="wd-step-body">
              <h3 class="wd-step-title">
                Release with
                <a href={`${base}/skills/version-sdlc/`} class="wd-skill-link">/version-sdlc</a>
              </h3>
              <p>
                Detects the version source file, analyzes conventional commits since the last tag
                to infer the bump type (major/minor/patch), and presents a release plan for approval.
                On approval: bumps the version file, creates an annotated git tag, and pushes to origin.
              </p>
            </div>
          </div>
        </div>
      </div>

      <!-- Configuration -->
      <div class="sp-section">
        <h2 class="sp-section-title">Configuration</h2>
        <p class="sp-section-desc">
          Run <code>/ship-sdlc --init-config</code> to generate <code>.sdlc/ship-config.json</code>.
          Presets let teams standardize their shipping flow.
        </p>
        <div class="sp-code-examples">
          <div class="sp-code-block">
            <span class="sp-code-label">Quick ship (skip review)</span>
            <pre><code>{`{
  "preset": "quick",
  "skipReview": true,
  "autoBumpType": "patch"
}`}</code></pre>
          </div>
          <div class="sp-code-block">
            <span class="sp-code-label">Full pipeline (default)</span>
            <pre><code>{`{
  "preset": "full",
  "skipReview": false,
  "autoFix": true
}`}</code></pre>
          </div>
        </div>
      </div>

      <!-- One-Time Setup -->
      <div class="wd-setup">
        <h2 class="wd-setup-title">One-Time Setup</h2>
        <p class="wd-setup-body">
          Run <a href={`${base}/skills/pr-customize-sdlc/`} class="wd-skill-link" style="--step-color: var(--color-gitops);">/pr-customize-sdlc</a> once per
          project to create a custom PR description template at <code>.claude/pr-template.md</code>.
          It scans your existing PR conventions, proposes a tailored template, and lets you refine it
          interactively. Once saved, <a href={`${base}/skills/pr-sdlc/`} class="wd-skill-link" style="--step-color: var(--color-gitops);">/pr-sdlc</a> uses
          it automatically for all future PRs.
        </p>
      </div>

      <!-- Where does it connect? -->
      <div class="wd-after">
        <h2 class="wd-after-title">Where does it connect?</h2>
        <div class="wd-after-paths">
          <a href={`${base}/workflows/plan-execute/`} class="wd-after-path" style="--path-color: var(--color-planning);">
            <span class="wd-path-label">From Plan & Execute</span>
            <span class="wd-path-desc">execute-plan-sdlc feeds completed work into the ship pipeline</span>
          </a>
          <a href={`${base}/workflows/review-cycle/`} class="wd-after-path" style="--path-color: var(--color-review);">
            <span class="wd-path-label">From Review Cycle</span>
            <span class="wd-path-desc">received-review-sdlc flows accepted fixes into commit-sdlc</span>
          </a>
          <a href={`${base}/workflows/openspec/`} class="wd-after-path" style="--path-color: var(--color-planning);">
            <span class="wd-path-label">Full Orchestration</span>
            <span class="wd-path-desc">ship-sdlc connects all three lanes into a single automated pipeline</span>
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ── Hero ── */
  .wd-hero {
    padding: 3rem 1.5rem 1.5rem;
  }

  .wd-hero-inner {
    max-width: 40rem;
    margin: 0 auto;
  }

  .wd-back {
    display: inline-block;
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    text-decoration: none;
    margin-bottom: 1rem;
    transition: color 0.12s ease;
  }

  .wd-back:hover {
    color: var(--color-text);
  }

  .wd-overline {
    display: inline-block;
    font-family: ui-monospace, 'SF Mono', 'Fira Code', monospace;
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--lane-color);
    margin-bottom: 0.75rem;
    padding: 3px 10px;
    border: 1px solid color-mix(in srgb, var(--lane-color) 30%, transparent);
    border-radius: 4px;
    background: color-mix(in srgb, var(--lane-color) 8%, transparent);
  }

  .wd-title {
    font-family: ui-monospace, 'SF Mono', 'Fira Code', monospace;
    font-size: clamp(1.5rem, 4vw, 2rem);
    font-weight: 700;
    color: var(--color-text);
    margin: 0 0 0.75rem;
    letter-spacing: -0.01em;
  }

  .wd-subtitle {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--color-text-muted);
    margin: 0;
  }

  /* ── Graph ── */
  .wd-graph-section {
    padding: 1rem 1.5rem 2rem;
  }

  .wd-graph-container {
    max-width: 72rem;
    margin: 0 auto;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    background: var(--color-bg);
    padding: 1.5rem;
    overflow: hidden;
  }

  /* ── Content ── */
  .wd-content {
    padding: 0 1.5rem 3rem;
  }

  .wd-content-inner {
    max-width: 40rem;
    margin: 0 auto;
  }

  /* ── Sections ── */
  .sp-section {
    margin-bottom: 3rem;
  }

  .sp-section-title {
    font-family: ui-monospace, 'SF Mono', 'Fira Code', monospace;
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--color-text);
    margin: 0 0 0.75rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .sp-section-desc {
    font-size: 0.875rem;
    line-height: 1.65;
    color: var(--color-text-muted);
    margin: 0 0 1.5rem;
  }

  .sp-section-desc code {
    font-family: ui-monospace, 'SF Mono', 'Fira Code', monospace;
    font-size: 0.8125rem;
    padding: 1px 5px;
    background: var(--color-surface-2);
    border-radius: 3px;
    color: var(--color-text);
  }

  /* ── Pipeline Visualization ── */
  .sp-pipeline {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
    padding: 1.5rem 0;
  }

  .sp-step {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    width: 100%;
    max-width: 22rem;
  }

  .sp-step-number {
    flex-shrink: 0;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: color-mix(in srgb, var(--color-gitops) 15%, transparent);
    border: 1.5px solid color-mix(in srgb, var(--color-gitops) 40%, transparent);
    color: var(--color-gitops);
    font-family: ui-monospace, 'SF Mono', 'Fira Code', monospace;
    font-size: 0.6875rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .sp-step-box {
    flex: 1;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.375rem 0.625rem;
    padding: 0.625rem 0.875rem;
    border: 1px solid color-mix(in srgb, var(--color-gitops) 30%, transparent);
    border-radius: 6px;
    background: color-mix(in srgb, var(--color-gitops) 6%, transparent);
    text-decoration: none;
    transition: border-color 0.12s ease, background 0.12s ease;
  }

  .sp-step-box:hover {
    border-color: color-mix(in srgb, var(--color-gitops) 50%, transparent);
    background: color-mix(in srgb, var(--color-gitops) 10%, transparent);
  }

  .sp-step-box--conditional {
    border-style: dashed;
  }

  .sp-step-label {
    font-family: ui-monospace, 'SF Mono', 'Fira Code', monospace;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .sp-step-skill {
    font-family: ui-monospace, 'SF Mono', 'Fira Code', monospace;
    font-size: 0.6875rem;
    color: var(--color-text-muted);
  }

  /* ── Connectors ── */
  .sp-connector {
    width: 2px;
    height: 1.25rem;
    background: color-mix(in srgb, var(--color-gitops) 35%, transparent);
    margin-left: calc(12px + 0.375rem);
  }

  .sp-connector--branch {
    height: 0.75rem;
    margin-left: 0;
    align-self: center;
  }

  .sp-connector--merge {
    height: 1.25rem;
    margin-left: calc(12px + 0.375rem);
  }

  /* ── Conditional Branch ── */
  .sp-branch {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
    max-width: 32rem;
    padding: 0;
  }

  .sp-branch-diamond {
    position: relative;
    padding: 0.5rem 1rem;
    border: 1.5px solid color-mix(in srgb, var(--color-review) 50%, transparent);
    border-radius: 6px;
    background: color-mix(in srgb, var(--color-review) 8%, transparent);
    text-align: center;
    margin-left: calc(24px + 0.75rem);
    max-width: 22rem;
    width: 100%;
    box-sizing: border-box;
  }

  .sp-branch-text {
    font-family: ui-monospace, 'SF Mono', 'Fira Code', monospace;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-review);
  }

  .sp-branch-paths {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    width: 100%;
    margin-top: 0.5rem;
    margin-left: calc(24px + 0.75rem);
    max-width: 22rem;
    box-sizing: border-box;
  }

  .sp-branch-yes {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
  }

  .sp-branch-no {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }

  .sp-branch-label {
    font-family: ui-monospace, 'SF Mono', 'Fira Code', monospace;
    font-size: 0.6875rem;
    font-weight: 600;
    padding: 1px 8px;
    border-radius: 3px;
    margin-bottom: 0.25rem;
  }

  .sp-branch-label--yes {
    color: var(--color-review);
    background: color-mix(in srgb, var(--color-review) 12%, transparent);
  }

  .sp-branch-label--no {
    color: var(--color-gitops);
    background: color-mix(in srgb, var(--color-gitops) 12%, transparent);
  }

  .sp-step--branch {
    max-width: none;
  }

  .sp-step--branch .sp-step-box {
    border-color: color-mix(in srgb, var(--color-review) 30%, transparent);
    background: color-mix(in srgb, var(--color-review) 6%, transparent);
  }

  .sp-step--branch .sp-step-box:hover {
    border-color: color-mix(in srgb, var(--color-review) 50%, transparent);
    background: color-mix(in srgb, var(--color-review) 10%, transparent);
  }

  /* ── Badges ── */
  .sp-badge {
    font-family: ui-monospace, 'SF Mono', 'Fira Code', monospace;
    font-size: 0.5625rem;
    font-weight: 600;
    padding: 1px 6px;
    border-radius: 3px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    white-space: nowrap;
  }

  .sp-badge--pause {
    color: var(--color-review);
    background: color-mix(in srgb, var(--color-review) 15%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-review) 30%, transparent);
  }

  .sp-badge--conditional {
    color: var(--color-text-muted);
    background: color-mix(in srgb, var(--color-text-muted) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-text-muted) 20%, transparent);
  }

  /* ── Auto Mode Table ── */
  .sp-table-wrap {
    overflow-x: auto;
    border: 1px solid var(--color-border);
    border-radius: 6px;
  }

  .sp-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.8125rem;
  }

  .sp-table th {
    font-family: ui-monospace, 'SF Mono', 'Fira Code', monospace;
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
    background: var(--color-surface);
    padding: 0.5rem 0.75rem;
    text-align: left;
    border-bottom: 1px solid var(--color-border);
  }

  .sp-table td {
    padding: 0.5rem 0.75rem;
    color: var(--color-text-muted);
    border-bottom: 1px solid color-mix(in srgb, var(--color-border) 50%, transparent);
  }

  .sp-table tr:last-child td {
    border-bottom: none;
  }

  .sp-table td:first-child {
    color: var(--color-text);
    font-weight: 500;
  }

  .sp-table a {
    font-family: ui-monospace, 'SF Mono', 'Fira Code', monospace;
    font-size: 0.75rem;
    color: var(--color-gitops);
    text-decoration: none;
    border-bottom: 1px solid color-mix(in srgb, var(--color-gitops) 30%, transparent);
    transition: border-color 0.12s ease;
  }

  .sp-table a:hover {
    border-color: var(--color-gitops);
  }

  .sp-table code {
    font-family: ui-monospace, 'SF Mono', 'Fira Code', monospace;
    font-size: 0.75rem;
    padding: 1px 4px;
    background: var(--color-surface-2);
    border-radius: 3px;
    color: var(--color-text);
  }

  .sp-pause-no {
    color: var(--color-gitops);
    font-weight: 600;
  }

  .sp-pause-yes {
    color: var(--color-review);
    font-weight: 600;
  }

  /* ── Code Examples ── */
  .sp-code-examples {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .sp-code-block {
    border: 1px solid var(--color-border);
    border-radius: 6px;
    overflow: hidden;
  }

  .sp-code-label {
    display: block;
    font-family: ui-monospace, 'SF Mono', 'Fira Code', monospace;
    font-size: 0.6875rem;
    font-weight: 600;
    color: var(--color-text-muted);
    padding: 0.5rem 0.75rem;
    background: var(--color-surface);

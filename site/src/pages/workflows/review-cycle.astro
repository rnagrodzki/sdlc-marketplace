---
import BaseLayout from '../../layouts/BaseLayout.astro';
import WorkflowGraph from '../../components/WorkflowGraph.astro';

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Review Cycle Workflow" description="How setup-sdlc, review-sdlc, and received-review-sdlc form a complete code review loop.">
  <section class="wd-hero">
    <div class="wd-hero-inner">
      <a href={`${base}/workflows/`} class="wd-back">&larr; All Workflows</a>
      <span class="wd-overline" style="--lane-color: var(--color-review);">Review Lane</span>
      <h1 class="wd-title">Review Cycle</h1>
      <p class="wd-subtitle">
        Multi-dimensional code review with dual critique gates that prevent blind acceptance of suggestions.
      </p>
    </div>
  </section>

  <section class="wd-graph-section">
    <div class="wd-graph-container">
      <WorkflowGraph highlightSlugs={['setup-sdlc', 'review-sdlc', 'received-review-sdlc']} />
    </div>
  </section>

  <section class="wd-content">
    <div class="wd-content-inner">
      <div class="wd-steps">
        <div class="wd-step" style="--step-color: var(--color-review);">
          <div class="wd-step-marker">1</div>
          <div class="wd-step-body">
            <h2 class="wd-step-title">
              Initialize with
              <a href={`${base}/skills/setup-sdlc/`} class="wd-skill-link">/setup-sdlc</a>
            </h2>
            <p>
              Scans your project's tech stack -- package.json, directory structure, file patterns --
              and proposes relevant review dimensions from a catalog of 31 types. You select which
              dimensions to install. Each dimension becomes a focused lens for code review.
            </p>
            <p>
              Dimension files are written to <code>.sdlc/review-dimensions/</code> and optionally
              mirrored as GitHub Copilot instruction files. This is typically a one-time setup,
              though you can re-run it when your stack changes.
            </p>
          </div>
        </div>

        <div class="wd-step" style="--step-color: var(--color-review);">
          <div class="wd-step-marker">2</div>
          <div class="wd-step-body">
            <h2 class="wd-step-title">
              Review with
              <a href={`${base}/skills/review-sdlc/`} class="wd-skill-link">/review-sdlc</a>
            </h2>
            <p>
              The core review skill loads your installed dimensions and matches them to the changed
              files via glob patterns. Parallel subagents review each matching dimension independently,
              then findings are deduplicated and merged into a consolidated report.
            </p>
            <p>
              The review can target different scopes: <code>--committed</code> for branch commits,
              <code>--staged</code> for what's about to be committed, or <code>--working</code> for
              uncommitted changes. The consolidated comment is posted to the PR via the GitHub CLI.
            </p>
          </div>
        </div>

        <div class="wd-step" style="--step-color: var(--color-review);">
          <div class="wd-step-marker">3</div>
          <div class="wd-step-body">
            <h2 class="wd-step-title">
              Respond with
              <a href={`${base}/skills/received-review-sdlc/`} class="wd-skill-link">/received-review-sdlc</a>
            </h2>
            <p>
              When review findings exist, this skill processes the feedback through two critique gates.
              First, it reads the actual code referenced in each finding and evaluates whether the
              suggestion is technically correct. Then a self-critique pass catches performative agreement
              or blind compliance.
            </p>
            <p>
              Accepted fixes are implemented in priority order. Thread replies are posted back to the
              PR, creating a traceable conversation. The output flows naturally into the ship lane --
              commit the fixes, update the PR.
            </p>
          </div>
        </div>
      </div>

      <div class="wd-after">
        <h2 class="wd-after-title">What happens next?</h2>
        <div class="wd-after-paths">
          <a href={`${base}/workflows/ship/`} class="wd-after-path" style="--path-color: var(--color-gitops);">
            <span class="wd-path-label">Commit the fixes</span>
            <span class="wd-path-desc">received-review-sdlc flows into commit-sdlc to package accepted changes</span>
          </a>
          <a href={`${base}/workflows/plan-execute/`} class="wd-after-path" style="--path-color: var(--color-planning);">
            <span class="wd-path-label">Review planned work</span>
            <span class="wd-path-desc">execute-plan-sdlc feeds its output into review-sdlc for quality checks</span>
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .wd-hero {
    padding: 3rem 1.5rem 1.5rem;
  }

  .wd-hero-inner {
    max-width: 40rem;
    margin: 0 auto;
  }

  .wd-back {
    display: inline-block;
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    text-decoration: none;
    margin-bottom: 1rem;
    transition: color 0.12s ease;
  }

  .wd-back:hover {
    color: var(--color-text);
  }

  .wd-overline {
    display: inline-block;
    font-family: ui-monospace, 'SF Mono', 'Fira Code', monospace;
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--lane-color);
    margin-bottom: 0.75rem;
    padding: 3px 10px;
    border: 1px solid color-mix(in srgb, var(--lane-color) 30%, transparent);
    border-radius: 4px;
    background: color-mix(in srgb, var(--lane-color) 8%, transparent);
  }

  .wd-title {
    font-family: ui-monospace, 'SF Mono', 'Fira Code', monospace;
    font-size: clamp(1.5rem, 4vw, 2rem);
    font-weight: 700;
    color: var(--color-text);
    margin: 0 0 0.75rem;
    letter-spacing: -0.01em;
  }

  .wd-subtitle {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--color-text-muted);
    margin: 0;
  }

  .wd-graph-section {
    padding: 1rem 1.5rem 2rem;
  }

  .wd-graph-container {
    max-width: 72rem;
    margin: 0 auto;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    background: var(--color-bg);
    padding: 1.5rem;
    overflow: hidden;
  }

  .wd-content {
    padding: 0 1.5rem 3rem;
  }

  .wd-content-inner {
    max-width: 40rem;
    margin: 0 auto;
  }

  .wd-steps {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    margin-bottom: 3rem;
  }

  .wd-step {
    display: flex;
    gap: 1.25rem;
  }

  .wd-step-marker {
    flex-shrink: 0;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: color-mix(in srgb, var(--step-color) 15%, transparent);
    border: 1.5px solid color-mix(in srgb, var(--step-color) 40%, transparent);
    color: var(--step-color);
    font-family: ui-monospace, 'SF Mono', 'Fira Code', monospace;
    font-size: 0.75rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 0.125rem;
  }

  .wd-step-body {
    flex: 1;
    min-width: 0;
  }

  .wd-step-title {
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--color-text);
    margin: 0 0 0.625rem;
    line-height: 1.4;
  }

  .wd-skill-link {
    font-family: ui-monospace, 'SF Mono', 'Fira Code', monospace;
    font-size: 0.9375rem;
    color: var(--step-color);
    text-decoration: none;
    border-bottom: 1px solid color-mix(in srgb, var(--step-color) 30%, transparent);
    transition: border-color 0.12s ease;
  }

  .wd-skill-link:hover {
    border-color: var(--step-color);
  }

  .wd-step-body p {
    font-size: 0.875rem;
    line-height: 1.65;
    color: var(--color-text-muted);
    margin: 0 0 0.75rem;
  }

  .wd-step-body p:last-child {
    margin-bottom: 0;
  }

  .wd-step-body code {
    font-family: ui-monospace, 'SF Mono', 'Fira Code', monospace;
    font-size: 0.8125rem;
    padding: 1px 5px;
    background: var(--color-surface-2);
    border-radius: 3px;
    color: var(--color-text);
  }

  .wd-after-title {
    font-family: ui-monospace, 'SF Mono', 'Fira Code', monospace;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin: 0 0 1rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }

  .wd-after-paths {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .wd-after-path {
    display: block;
    padding: 1rem 1rem 1rem 1.125rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-left: 3px solid var(--path-color);
    border-radius: 6px;
    text-decoration: none;
    transition: transform 0.12s ease, box-shadow 0.12s ease;
  }

  .wd-after-path:hover {
    transform: translateY(-1px);
    box-shadow: 0 2px 12px -2px color-mix(in srgb, var(--path-color) 15%, transparent);
  }

  .wd-path-label {
    display: block;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 0.375rem;
  }

  .wd-path-desc {
    display: block;
    font-size: 0.75rem;
    line-height: 1.5;
    color: var(--color-text-muted);
  }

  @media (max-width: 640px) {
    .wd-hero {
      padding: 2rem 1rem 1rem;
    }

    .wd-graph-section,
    .wd-content {
      padding-left: 1rem;
      padding-right: 1rem;
    }

    .wd-graph-container {
      padding: 1rem;
    }

    .wd-after-paths {
      grid-template-columns: 1fr;
    }
  }
</style>

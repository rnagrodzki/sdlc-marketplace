---
import { render, getEntry } from 'astro:content';
import GuideLayout from '../layouts/GuideLayout.astro';

const entry = await getEntry('guides', 'architecture');
if (!entry) throw new Error('architecture.md not found in guides collection');
const { Content } = await render(entry);
---

<GuideLayout title="Architecture" description="Repository structure, the plugin system, and how name resolution works in the SDLC Marketplace.">
  <Content />
</GuideLayout>

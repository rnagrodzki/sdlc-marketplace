---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  parentHref?: string;
  parentLabel?: string;
}

const { title, description, parentHref, parentLabel } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<BaseLayout title={title} description={description}>
  <div class="guide-page">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <ol>
        <li><a href={`${base}/`}>Home</a></li>
        {parentHref && parentLabel && (
          <li><a href={parentHref}>{parentLabel}</a></li>
        )}
        <li aria-current="page">{title}</li>
      </ol>
    </nav>

    <div class="guide-grid">
      <aside class="guide-toc" id="guide-toc">
        <button
          class="toc-toggle"
          type="button"
          aria-expanded="false"
          aria-controls="toc-list"
        >
          On this page
          <svg class="toc-toggle-arrow" width="10" height="6" viewBox="0 0 10 6" fill="none" aria-hidden="true">
            <path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </button>
        <nav class="toc-nav" id="toc-list" aria-label="Table of contents">
          <!-- Populated by client JS -->
        </nav>
      </aside>

      <article class="guide-content">
        <h1 class="guide-title">{title}</h1>
        <slot />
      </article>
    </div>
  </div>
</BaseLayout>

<script>
  function buildTOC() {
    const content = document.querySelector('.guide-content');
    const tocNav = document.getElementById('toc-list');
    if (!content || !tocNav) return;

    const headings = content.querySelectorAll('h2, h3');
    if (headings.length === 0) {
      const toc = document.getElementById('guide-toc');
      if (toc) toc.style.display = 'none';
      return;
    }

    const list = document.createElement('ul');
    list.className = 'toc-list';

    headings.forEach((heading) => {
      if (!heading.id) {
        heading.id = heading.textContent!
          .toLowerCase()
          .replace(/[^\w\s-]/g, '')
          .replace(/\s+/g, '-');
      }

      const li = document.createElement('li');
      li.className = heading.tagName === 'H3' ? 'toc-item toc-item--nested' : 'toc-item';

      const a = document.createElement('a');
      a.href = `#${heading.id}`;
      a.textContent = heading.textContent;
      a.className = 'toc-link';

      li.appendChild(a);
      list.appendChild(li);
    });

    tocNav.appendChild(list);

    // Mobile toggle
    const toggle = document.querySelector('.toc-toggle') as HTMLButtonElement | null;
    if (toggle) {
      toggle.addEventListener('click', () => {
        const expanded = toggle.getAttribute('aria-expanded') === 'true';
        toggle.setAttribute('aria-expanded', String(!expanded));
        tocNav.classList.toggle('open');
      });
    }
  }

  buildTOC();
</script>

<style>
  .guide-page {
    max-width: 72rem;
    margin: 0 auto;
    padding: 2rem 1.5rem;
  }

  /* Breadcrumb */
  .breadcrumb ol {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    list-style: none;
    margin: 0 0 1.5rem;
    padding: 0;
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }

  .breadcrumb li + li::before {
    content: '/';
    margin-right: 0.25rem;
    opacity: 0.4;
  }

  .breadcrumb a {
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.12s ease;
  }

  .breadcrumb a:hover {
    color: var(--color-text);
  }

  .breadcrumb [aria-current='page'] {
    color: var(--color-text);
  }

  /* Grid: TOC sidebar + content */
  .guide-grid {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 3rem;
    align-items: start;
  }

  /* TOC sidebar */
  .guide-toc {
    position: sticky;
    top: 5rem;
  }

  .toc-toggle {
    display: none;
    width: 100%;
    background: none;
    border: none;
    color: var(--color-text-muted);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.5rem 0;
    cursor: pointer;
    justify-content: space-between;
    align-items: center;
  }

  .toc-toggle:hover {
    color: var(--color-text);
  }

  .toc-toggle:focus-visible {
    outline: 2px solid var(--color-planning);
    outline-offset: 2px;
  }

  .toc-toggle-arrow {
    transition: transform 0.15s ease;
  }

  .toc-toggle[aria-expanded='true'] .toc-toggle-arrow {
    transform: rotate(180deg);
  }

  .toc-nav :global(.toc-list) {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .toc-nav :global(.toc-item) {
    margin: 0;
  }

  .toc-nav :global(.toc-item--nested) {
    padding-left: 0.75rem;
  }

  .toc-nav :global(.toc-link) {
    display: block;
    padding: 0.25rem 0.5rem;
    font-size: 0.75rem;
    line-height: 1.5;
    color: var(--color-text-muted);
    text-decoration: none;
    border-left: 1px solid var(--color-border);
    transition: color 0.12s ease, border-color 0.12s ease;
  }

  .toc-nav :global(.toc-link:hover) {
    color: var(--color-text);
    border-left-color: var(--color-text-muted);
  }

  .toc-nav :global(.toc-link:focus-visible) {
    outline: 2px solid var(--color-planning);
    outline-offset: -2px;
  }

  /* Content */
  .guide-content {
    max-width: 75ch;
    font-size: 0.9375rem;
    line-height: 1.75;
  }

  .guide-title {
    margin: 0 0 1.5rem;
    font-size: 1.75rem;
    font-weight: 700;
    line-height: 1.25;
    color: var(--color-text);
  }

  /* Prose styling */
  .guide-content :global(h2) {
    margin: 2.5rem 0 0.75rem;
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-text);
  }

  .guide-content :global(h3) {
    margin: 2rem 0 0.5rem;
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .guide-content :global(p) {
    margin: 0 0 1rem;
    color: var(--color-text);
  }

  .guide-content :global(code) {
    font-family: 'SF Mono', 'Fira Code', 'Fira Mono', 'Roboto Mono', 'Courier New', monospace;
    font-size: 0.875em;
    background: var(--color-surface);
    padding: 0.125rem 0.375rem;
    border-radius: 3px;
    border: 1px solid var(--color-border);
  }

  .guide-content :global(pre) {
    margin: 0 0 1.5rem;
    padding: 1rem 1.25rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    overflow-x: auto;
    font-size: 0.8125rem;
    line-height: 1.6;
  }

  .guide-content :global(pre code) {
    background: none;
    padding: 0;
    border: none;
    border-radius: 0;
  }

  .guide-content :global(ul),
  .guide-content :global(ol) {
    margin: 0 0 1rem;
    padding-left: 1.5rem;
  }

  .guide-content :global(li) {
    margin-bottom: 0.25rem;
  }

  .guide-content :global(a) {
    color: var(--color-planning);
    text-decoration: none;
    border-bottom: 1px solid color-mix(in srgb, var(--color-planning) 30%, transparent);
    transition: border-color 0.12s ease;
  }

  .guide-content :global(a:hover) {
    border-bottom-color: var(--color-planning);
  }

  .guide-content :global(table) {
    width: 100%;
    margin: 0 0 1.5rem;
    border-collapse: collapse;
    font-size: 0.875rem;
  }

  .guide-content :global(th),
  .guide-content :global(td) {
    padding: 0.5rem 0.75rem;
    text-align: left;
    border-bottom: 1px solid var(--color-border);
  }

  .guide-content :global(th) {
    font-weight: 600;
    color: var(--color-text);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .guide-content :global(td) {
    color: var(--color-text-muted);
  }

  /* Mobile */
  @media (max-width: 768px) {
    .guide-grid {
      grid-template-columns: 1fr;
      gap: 0;
    }

    .guide-toc {
      position: static;
      margin-bottom: 1.5rem;
      border-bottom: 1px solid var(--color-border);
      padding-bottom: 0.75rem;
    }

    .toc-toggle {
      display: flex;
    }

    .toc-nav {
      display: none;
      padding-top: 0.5rem;
    }

    .toc-nav.open {
      display: block;
    }

    .guide-content {
      max-width: none;
    }
  }
</style>

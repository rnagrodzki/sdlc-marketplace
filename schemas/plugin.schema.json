{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/rnagrodzki/sdlc-marketplace/main/schemas/plugin.schema.json",
  "title": "Plugin Manifest",
  "description": "Validates plugins/*/.claude-plugin/plugin.json",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(-[\\w][\\w.-]*)?(\\+[\\w][\\w.-]*)?$"
    },
    "author": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        }
      },
      "required": ["name"]
    }
  },
  "required": ["name", "description", "version"],
  "additionalProperties": false
}

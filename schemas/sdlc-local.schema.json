{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/rnagrodzki/sdlc-marketplace/main/schemas/sdlc-local.schema.json",
  "title": "SDLC Local Config",
  "description": "Validates .sdlc/local.json — user-local (gitignored) configuration for sdlc-utilities skills.",
  "type": "object",
  "$defs": {
    "reviewSection": {
      "type": "object",
      "description": "User-local defaults for the review-sdlc skill.",
      "properties": {
        "scope": {
          "type": "string",
          "enum": ["all", "committed", "staged", "working", "worktree"],
          "description": "Which changes to include in the review."
        }
      },
      "additionalProperties": false
    },
    "shipSection": {
      "type": "object",
      "description": "Controls the ship-sdlc skill behaviour.",
      "properties": {
        "steps": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["execute", "commit", "review", "version", "pr", "archive-openspec"]
          },
          "uniqueItems": true,
          "description": "Pipeline steps to run. Replaces legacy preset/skip fields."
        },
        "bump": {
          "type": "string",
          "enum": ["patch", "minor", "major"],
          "description": "Version bump level."
        },
        "draft": {
          "type": "boolean",
          "description": "Open the pull request as a draft."
        },
        "auto": {
          "type": "boolean",
          "description": "Run the pipeline non-interactively."
        },
        "reviewThreshold": {
          "type": "string",
          "enum": ["critical", "high", "medium"],
          "description": "Minimum severity level that blocks the pipeline."
        },
        "workspace": {
          "type": "string",
          "enum": ["branch", "worktree", "prompt"],
          "description": "How to set up the working environment for the ship run."
        },
        "rebase": {
          "description": "Whether to rebase before shipping, or prompt the user.",
          "oneOf": [
            {
              "type": "boolean"
            },
            {
              "type": "string",
              "const": "prompt"
            }
          ]
        }
      },
      "additionalProperties": false
    }
  },
  "properties": {
    "$schema": {
      "type": "string",
      "description": "URL pointing to this schema."
    },
    "version": {
      "type": "integer",
      "const": 2,
      "description": "Schema version of this local config file. Current version is 2; v1 files (no version field, with ship.preset/ship.skip) are auto-migrated on read."
    },
    "review": {
      "$ref": "#/$defs/reviewSection"
    },
    "ship": {
      "$ref": "#/$defs/shipSection"
    }
  },
  "additionalProperties": false
}
